# ─────────────────────────────────────────────
# MAB AI Strategies — Environment Variables
# Copy this file to .env.local for local development
# NEVER commit .env.local to version control
# ─────────────────────────────────────────────

# ── Contact Form Webhook ──────────────────────
# URL of your webhook endpoint (n8n / Make / Zapier / custom API)
# Example n8n:   https://your-n8n.com/webhook/contact-form
# Example Zapier: https://hooks.zapier.com/hooks/catch/XXXXXX/YYYYYY/
CONTACT_WEBHOOK_URL=

# Shared secret sent in X-Webhook-Secret header for verification
CONTACT_WEBHOOK_SECRET=

# ── Email Notifications ───────────────────────
# Address that receives new lead notifications
NOTIFY_EMAIL=mark@mabaistrategies.com

# ── Rate Limiting (optional — Upstash Redis) ──
# Obtain from https://upstash.com
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Public / Client-side Variables ───────────
# These are safe to expose to the browser (must be prefixed NEXT_PUBLIC_)
NEXT_PUBLIC_GOOGLE_CALENDAR_URL=https://calendar.app.google/kuwKF2VrDuyvdfN9A
NEXT_PUBLIC_LINKEDIN_URL=https://www.linkedin.com/in/mark-bockrath-a5a1b2196/
NEXT_PUBLIC_TWITTER_URL=https://x.com/mab_ai_CEO
NEXT_PUBLIC_EMAIL=mark@mabaistrategies.com
NEXT_PUBLIC_SUPPORT_EMAIL=contact@mabaistrategies.com
NEXT_PUBLIC_SITE_URL=https://mabaistrategies.com

# ── Analytics (add when ready) ───────────────
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
